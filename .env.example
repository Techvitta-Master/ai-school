# Copy to `.env` and fill in values. Never commit `.env`.

# Supabase (browser + API server)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: server-only duplicates if you do not rely on VITE_* in Node
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Direct Postgres URI for `npm run migrate` only (not the anon key).
# Supabase Dashboard → Project Settings → Database → Connection string → URI.
# Prefer "Session" or "Direct" for DDL; append ?sslmode=require if the client requires SSL.
DATABASE_URL=

# Alias supported by scripts/run-migrations.mjs if you prefer:
# DIRECT_URL=
