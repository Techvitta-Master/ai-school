# Copy to `.env` and fill in values. Never commit `.env`.

# Supabase (browser + API server)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: server-only duplicates if you do not rely on VITE_* in Node
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Direct Postgres URI for `npm run migrate` only (not the anon key).
# Supabase Dashboard → Project Settings → Database → Connection string → URI.
# Prefer "Session" or "Direct" for DDL; append ?sslmode=require if the client requires SSL.
DATABASE_URL=

# Alias supported by scripts/run-migrations.mjs if you prefer:
# DIRECT_URL=

# AI evaluation feature flags
VITE_ENABLE_AI_EVALUATION=false
AI_EVALUATION_ENABLED=false

# OCR provider (server-side only, never expose via VITE_*)
SARVAM_API_SUBSCRIPTION_KEY=

# Optional override endpoint if your Sarvam account uses a different route
SARVAM_OCR_URL=

# Grading LLM (server-side only)
AI_EVAL_LLM_URL=
AI_EVAL_LLM_API_KEY=
AI_EVAL_LLM_MODEL=
